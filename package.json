{
    "name": "playground-cli",
    "description": "CLI for Polkadot Playground",
    "version": "0.33.1",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "packageManager": "pnpm@11.5.2",
    "bin": {
        "playground": "./src/index.ts",
        "pg": "./src/index.ts"
    },
    "scripts": {
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint:license": "./scripts/check-license-headers.sh",
        "typecheck": "tsc --noEmit",
        "build": "bun build --compile src/index.ts --outfile ./dist/playground",
        "cli:install": "bun build --compile src/index.ts --outfile ~/.polkadot/bin/playground && ln -sf ~/.polkadot/bin/playground ~/.polkadot/bin/pg",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "vitest run --config e2e/vitest.config.ts",
        "test:e2e:smoke": "tools/e2e-local.sh smoke",
        "test:e2e:pr": "tools/e2e-local.sh pr",
        "test:e2e:nightly": "tools/e2e-local.sh nightly"
    },
    "dependencies": {
        "@parity/cdm-builder": "3.1.5",
        "@parity/cdm-codegen": "0.6.18",
        "@parity/cdm-env": "^2.0.5",
        "@parity/dotns-cli": "0.6.6",
        "@parity/product-sdk-address": "^0.1.1",
        "@parity/product-sdk-cloud-storage": "^0.6.0",
        "@parity/product-sdk-contracts": "^0.7.3",
        "@parity/product-sdk-descriptors": "^0.6.0",
        "@parity/product-sdk-keys": "^0.3.6",
        "@parity/product-sdk-logger": "^0.1.1",
        "@parity/product-sdk-terminal": "^0.4.0",
        "@parity/product-sdk-tx": "^0.2.10",
        "@parity/product-sdk-utils": "^0.1.1",
        "@polkadot-api/sdk-ink": "^0.7.0",
        "@scure/sr25519": "^2.2.0",
        "@sentry/node": "^9.47.1",
        "bulletin-deploy": "0.10.0",
        "commander": "^12.0.0",
        "ink": "^5.2.1",
        "polkadot-api": "^2.1.6",
        "react": "^18.3.1",
        "react-devtools-core": "file:stubs/react-devtools-core",
        "tar": "^7.5.16"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@changesets/cli": "^2.31.0",
        "@types/node": "^22.15.3",
        "@types/react": "^18.3.18",
        "@types/tar": "^7.0.87",
        "execa": "^9.6.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.8"
    }
}
